{
  "name": "sky-markdown",
  "version": "0.1.0",
  "description": "Sky Markdown — a Typora-like WYSIWYG Markdown editor for Windows",
  "main": "./out/main/index.js",
  "author": "yanjunjie",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "build": "electron-vite build",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "build:win": "electron-vite build && electron-builder --win"
  },
  "dependencies": {
    "@milkdown/kit": "^7.5.0",
    "@milkdown/plugin-clipboard": "^7.5.0",
    "@milkdown/plugin-history": "^7.5.0",
    "@milkdown/plugin-indent": "^7.5.0",
    "@milkdown/plugin-listener": "^7.5.0",
    "@milkdown/plugin-trailing": "^7.5.0",
    "@milkdown/preset-commonmark": "^7.5.0",
    "@milkdown/preset-gfm": "^7.5.0",
    "@milkdown/utils": "^7.5.0",
    "prosemirror-state": "^1.4.3",
    "prosemirror-view": "^1.34.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "rcedit": "^5.0.2",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  }
}
